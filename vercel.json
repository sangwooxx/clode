{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["fra1"],
  "functions": {
    "api/index.py": {
      "regions": ["fra1"],
      "includeFiles": "shared/contracts/**",
      "excludeFiles": "{tmp/**,tests/**,docs/**,.git/**,**/__pycache__/**,backend/var/**,scripts/**,frontend/**,config/**,data/**}"
    }
  },
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "/api/index.py?__clode_path=$1"
    }
  ]
}

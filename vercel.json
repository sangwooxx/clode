{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["fra1"],
  "functions": {
    "api/index.py": {
      "regions": ["fra1"],
      "excludeFiles": "{tmp/**,tests/**,docs/**,.git/**,**/__pycache__/**,backend/var/**,scripts/**,frontend/**,shared/**,config/**,data/**,app/**}"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/index.py?__clode_path=$1"
    },
    {
      "src": "^/$",
      "dest": "/app/index.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "/app/index.html"
    }
  ]
}

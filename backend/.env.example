CLODE_BACKEND_HOST=127.0.0.1
CLODE_BACKEND_PORT=8787
# Example local SQLite: sqlite:///C:/path/to/clode/backend/var/clode.db
# Example Vercel/Postgres: postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
CLODE_DATABASE_URL=sqlite:///./backend/var/clode.db
# Optional Boxly-style alias supported by the backend runtime:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# Optional demo seed used for first boot on Vercel / fresh SQLite runtime
# CLODE_DATABASE_SEED_PATH=./backend/seed/clode-demo.db

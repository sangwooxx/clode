{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HoursMonth",
  "type": "object",
  "required": ["id", "month_key", "month_label", "selected", "visible_investments", "finance"],
  "properties": {
    "id": { "type": "string" },
    "month_key": { "type": "string" },
    "month_label": { "type": "string" },
    "selected": { "type": "boolean" },
    "visible_investments": {
      "type": "array",
      "items": { "type": "string" }
    },
    "finance": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    }
  }
}

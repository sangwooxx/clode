{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Invoice",
  "type": "object",
  "required": ["id", "contract_id", "type", "issue_date", "invoice_number"],
  "properties": {
    "id": { "type": "string" },
    "contract_id": { "type": ["string", "null"] },
    "contract_name": { "type": "string" },
    "type": { "enum": ["cost", "sales"] },
    "issue_date": { "type": "string" },
    "invoice_number": { "type": "string" },
    "counterparty_name": { "type": "string" },
    "category_or_description": { "type": "string" },
    "cost_category": { "enum": ["materials", "labor", "equipment", "transport", "services", "other", ""] },
    "notes": { "type": "string" },
    "amount_net": { "type": "number" },
    "vat_rate": { "type": "number" },
    "amount_vat": { "type": "number" },
    "amount_gross": { "type": "number" },
    "due_date": { "type": "string" },
    "payment_date": { "type": "string" },
    "payment_status": { "enum": ["unpaid", "paid", "overdue"] }
  }
}
